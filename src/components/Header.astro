---
const pathname = Astro.url.pathname;

const nav = [
  { href: "/garden/", label: "Garden" },
  { href: "/writing/", label: "Writing" },
  { href: "/projects/", label: "Projects" },
  { href: "/about/", label: "About" },
];
---

<header class="border-b rule">
  <div
    class="shell flex min-h-20 items-center justify-between gap-5 py-4 max-md:flex-wrap"
  >
    <a
      class="font-serif text-2xl font-semibold tracking-[0.14em] no-underline"
      href="/"
      aria-label="Kadphol home"
    >
      KADPHOL
    </a>

    <nav
      class="flex items-center gap-8 text-sm font-medium max-md:order-3 max-md:w-full max-md:justify-between max-md:gap-3"
      aria-label="Primary navigation"
    >
      {
        nav.map(({ href, label }) => (
          <a
            class:list={[
              "border-b-2 py-1 no-underline transition-colors",
              pathname.startsWith(href)
                ? "border-[var(--accent)] text-[var(--accent)]"
                : "border-transparent hover:border-[var(--rule)]",
            ]}
            href={href}
            aria-current={pathname.startsWith(href) ? "page" : undefined}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/search/"
        class="inline-flex h-10 items-center gap-2 border rule px-3 text-sm no-underline hover:border-[var(--accent)]"
        aria-label="Search the garden"
      >
        <svg
          aria-hidden="true"
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <span class="max-sm:hidden">Search</span>
        <kbd
          class="text-muted ml-2 border rule px-1 font-sans text-[0.65rem] max-lg:hidden"
          >⌘K</kbd
        >
      </a>
      <button
        id="theme-toggle"
        class="grid size-10 place-items-center border rule bg-transparent hover:border-[var(--accent)]"
        type="button"
        aria-label="Toggle dark mode"
      >
        <svg
          class="theme-icon-light"
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <svg
          class="theme-icon-dark hidden"
          aria-hidden="true"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <path d="M20.5 14.2A8.5 8.5 0 0 1 9.8 3.5a8.5 8.5 0 1 0 10.7 10.7Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("#theme-toggle");
  const syncIcons = () => {
    const dark = document.documentElement.dataset.theme === "dark";
    toggle
      ?.querySelector(".theme-icon-light")
      ?.classList.toggle("hidden", dark);
    toggle
      ?.querySelector(".theme-icon-dark")
      ?.classList.toggle("hidden", !dark);
  };

  syncIcons();
  toggle?.addEventListener("click", () => {
    const dark = document.documentElement.dataset.theme === "dark";
    const theme = dark ? "light" : "dark";
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    syncIcons();
  });

  document.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      window.location.href = "/search/";
    }
  });
</script>
