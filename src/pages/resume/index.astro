---
import ContactGate from "@/components/ContactGate.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { resume } from "@/data/resume";

const description =
  "Full-stack developer and frontend engineering lead based in Bangkok, Thailand.";
const canonical = new URL("/resume/", Astro.site).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: resume.name,
  jobTitle: resume.role,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Bangkok",
    addressCountry: "TH",
  },
  url: canonical,
  sameAs: resume.publicLinks.map(({ href }) => href),
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: resume.education.institution,
  },
};
---

<BaseLayout
  title={`${resume.name} — Resume`}
  {description}
  {canonical}
  type="article"
  {structuredData}
  showChrome={false}
>
  <article class="resume shell">
    <header class="resume-header">
      <div class="resume-header__identity">
        <h1 class="display m-0 text-[clamp(3.5rem,7vw,6.5rem)]">
          {resume.name}
        </h1>
        <p class="resume-header__role">
          {resume.role}
          <span aria-hidden="true">·</span>
          {resume.location}
        </p>
      </div>

      <div class="resume-header__contact">
        <nav class="resume-links" aria-label="Professional profiles">
          {
            resume.publicLinks.map(({ label, href }) => (
              <a href={href} rel="me">
                <span aria-hidden="true">↗</span>
                {label}
              </a>
            ))
          }
        </nav>
        <ContactGate />
      </div>
    </header>

    <section class="resume-summary" aria-labelledby="summary-heading">
      <h2 id="summary-heading" class="sr-only">Professional summary</h2>
      <p>{resume.summary}</p>
    </section>

    <section aria-labelledby="experience-heading">
      <div class="resume-section-heading">
        <span class="font-serif text-4xl text-accent">01</span>
        <h2 id="experience-heading" class="display m-0 text-4xl">Experience</h2>
      </div>

      <ol class="resume-timeline">
        {
          resume.experience.map((experience) => (
            <li class="resume-role">
              <div class="resume-role__meta">
                <time>{experience.start}</time>
                <span>{experience.end}</span>
                <small>{experience.location}</small>
              </div>
              <div class="resume-role__body">
                <h3>{experience.role}</h3>
                <p class="resume-role__company">{experience.company}</p>
                <p class="resume-role__impact">{experience.impact}</p>
                <ul class="resume-role__details">
                  {experience.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
                <ul class="resume-technologies" aria-label="Technologies">
                  {experience.technologies.map((technology) => (
                    <li>{technology}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="resume-lower-grid">
      <div>
        <div class="resume-section-heading">
          <span class="font-serif text-4xl text-accent">02</span>
          <h2 class="display m-0 text-4xl">Education</h2>
        </div>
        <div class="resume-education">
          <p class="eyeline text-accent">
            {resume.education.start} — {resume.education.end}
          </p>
          <h3>{resume.education.degree}</h3>
          <p>{resume.education.institution}</p>
          <p class="text-muted">
            {resume.education.distinction} · GPA {resume.education.gpa}
          </p>
        </div>
      </div>

      <div>
        <div class="resume-section-heading">
          <span class="font-serif text-4xl text-accent">03</span>
          <h2 class="display m-0 text-4xl">Skills</h2>
        </div>
        <dl class="resume-skills">
          {
            resume.skills.map(({ label, items }) => (
              <div>
                <dt>{label}</dt>
                <dd>{items.join(" · ")}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .resume {
    width: min(100% - 2rem, 66rem);
    padding-block: 3.5rem 6rem;
  }

  .resume-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 17rem;
    gap: 3rem;
    align-items: end;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2rem;
  }

  .resume-header__role {
    margin: 0.8rem 0 0;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .resume-header__contact {
    display: grid;
    gap: 0.7rem;
  }

  .resume-links {
    display: grid;
    gap: 0.25rem;
    font-size: 0.84rem;
  }

  .resume-links a {
    width: fit-content;
    color: var(--accent);
    text-decoration-color: var(--rule);
  }

  .resume-summary {
    margin-left: 8.75rem;
    border-bottom: 1px solid var(--rule);
    padding: 2rem 0;
  }

  .resume-summary p {
    margin: 0;
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    font-weight: 550;
    line-height: 1.6;
  }

  .resume-section-heading {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    border-bottom: 1px solid var(--accent);
    padding: 2.5rem 0 0.8rem;
  }

  .resume-timeline {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-role {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr);
    gap: 1.75rem;
    border-bottom: 1px solid var(--rule);
    padding-block: 2rem;
  }

  .resume-role__meta {
    display: flex;
    flex-direction: column;
    color: var(--muted);
    font-size: 0.74rem;
    line-height: 1.45;
  }

  .resume-role__meta small {
    margin-top: 0.65rem;
  }

  .resume-role__body h3,
  .resume-education h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 570;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .resume-role__company {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .resume-role__impact {
    border-left: 2px solid var(--accent);
    margin: 1rem 0 0;
    padding-left: 0.75rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .resume-role__details {
    margin: 0.8rem 0 0;
    padding-left: 1.25rem;
    list-style: disc outside;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .resume-role__details li {
    display: list-item;
    padding-left: 0.2rem;
  }

  .resume-role__details li::marker {
    color: var(--accent);
    font-size: 0.8em;
  }

  .resume-role__details li + li {
    margin-top: 0.25rem;
  }

  .resume-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
  }

  .resume-technologies li::before {
    content: "#";
    color: var(--accent);
  }

  .resume-lower-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .resume-education {
    padding-top: 1.5rem;
  }

  .resume-education p {
    margin-block: 0.5rem;
  }

  .resume-skills {
    margin: 0;
    padding-top: 1.1rem;
  }

  .resume-skills div {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1rem;
    border-bottom: 1px solid var(--rule);
    padding-block: 0.8rem;
  }

  .resume-skills dt {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 0.84rem;
  }

  .resume-skills dd {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 0.84rem;
  }

  @media (max-width: 48rem) {
    .resume {
      width: min(100% - 1.25rem, 66rem);
      padding-top: 2rem;
    }

    .resume-header {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.5rem;
    }

    .resume-summary {
      margin-left: 0;
    }

    .resume-role {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .resume-role__meta {
      display: grid;
      grid-template-columns: auto auto 1fr;
      gap: 0.45rem;
      align-items: baseline;
    }

    .resume-role__meta small {
      margin: 0;
      text-align: right;
    }

    .resume-lower-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  @media print {
    :global(header),
    :global(footer),
    :global(.contact-list) {
      display: none !important;
    }

    .resume {
      width: 100%;
      padding: 0;
    }
  }
</style>
