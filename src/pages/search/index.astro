---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search — Kadphol"
  description="Search across garden notes, writing, and projects."
>
  <section class="shell pt-14">
    <h1 class="display m-0 text-[clamp(4rem,8vw,7rem)]">Search</h1>
    <p class="mt-4 text-xl text-muted">
      Search across garden notes, writing, and projects.
    </p>

    <div class="mt-12 max-w-4xl">
      <label class="eyeline mb-3 block" for="site-search"
        >Search the archive</label
      >
      <div class="flex border border-[var(--accent)]">
        <svg
          class="m-4 shrink-0"
          aria-hidden="true"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <input
          id="site-search"
          class="min-w-0 flex-1 border-0 bg-transparent px-2 py-5 text-lg outline-none"
          type="search"
          placeholder="Try “cancellation”, “architecture”, or “CLI”"
          autocomplete="off"
          autofocus
        />
      </div>
      <p id="search-status" class="mt-4 text-sm text-muted" aria-live="polite">
        Start typing to search all published content.
      </p>
      <div id="search-results" class="mt-8 border-t border-[var(--accent)]">
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  interface SearchRecord {
    title: string;
    description: string;
    href: string;
    type: string;
    tags: string[];
    content: string;
  }

  const input = document.querySelector<HTMLInputElement>("#site-search");
  const results = document.querySelector<HTMLElement>("#search-results");
  const status = document.querySelector<HTMLElement>("#search-status");
  const index = await fetch("/search-index.json").then(
    (response) => response.json() as Promise<SearchRecord[]>,
  );

  const score = (record: SearchRecord, terms: string[]) => {
    const title = record.title.toLowerCase();
    const metadata =
      `${record.description} ${record.tags.join(" ")} ${record.type}`.toLowerCase();
    const content = record.content.toLowerCase();

    return terms.reduce((total, term) => {
      if (
        !title.includes(term) &&
        !metadata.includes(term) &&
        !content.includes(term)
      ) {
        return -1000;
      }
      return (
        total +
        (title.includes(term) ? 8 : 0) +
        (metadata.includes(term) ? 4 : 0) +
        (content.includes(term) ? 1 : 0)
      );
    }, 0);
  };

  const render = () => {
    if (!input || !results || !status) return;
    const query = input.value.trim();
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    results.replaceChildren();

    if (terms.length === 0) {
      status.textContent = "Start typing to search all published content.";
      return;
    }

    const matches = index
      .map((record) => ({ record, score: score(record, terms) }))
      .filter(({ score }) => score >= 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 20);

    status.textContent = `${matches.length} ${matches.length === 1 ? "result" : "results"} for “${query}”`;

    matches.forEach(({ record }, position) => {
      const article = document.createElement("article");
      article.className =
        "grid grid-cols-[4rem_minmax(0,1fr)_1.5rem] gap-5 border-b border-[var(--rule)] py-6 max-sm:grid-cols-[2.5rem_minmax(0,1fr)]";

      const number = document.createElement("span");
      number.className = "font-serif text-2xl text-[var(--accent)]";
      number.textContent = String(position + 1).padStart(2, "0");

      const body = document.createElement("div");
      const meta = document.createElement("p");
      meta.className = "eyeline mb-2 text-[var(--accent)]";
      meta.textContent = `${record.type} · ${record.tags.join(" · ")}`;
      const title = document.createElement("h2");
      title.className = "m-0 text-xl font-semibold tracking-[-0.02em]";
      const link = document.createElement("a");
      link.className = "no-underline";
      link.href = record.href;
      link.textContent = record.title;
      title.append(link);
      const description = document.createElement("p");
      description.className = "mb-0 mt-2 text-sm text-[var(--muted)]";
      description.textContent = record.description;
      body.append(meta, title, description);

      const arrow = document.createElement("span");
      arrow.className = "text-xl text-[var(--accent)] max-sm:hidden";
      arrow.ariaHidden = "true";
      arrow.textContent = "→";

      article.append(number, body, arrow);
      results.append(article);
    });
  };

  const params = new URLSearchParams(window.location.search);
  if (input && params.get("q")) input.value = params.get("q") ?? "";
  input?.addEventListener("input", render);
  render();
</script>
