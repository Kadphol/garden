---
import ContentRow from "@/components/ContentRow.astro";
import EmptyState from "@/components/EmptyState.astro";
import { getPublishedPosts } from "@/lib/content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = await getPublishedPosts();
const years = Map.groupBy(posts, (entry) => entry.data.date.getFullYear());
---

<BaseLayout
  title="Writing — Kadphol"
  description="Dated essays, tutorials, and field notes on software engineering."
>
  <section class="shell pt-14">
    <h1 class="display m-0 text-[clamp(4rem,8vw,7rem)]">Writing</h1>
    <p class="mt-4 max-w-2xl text-xl text-muted">
      Dated essays, tutorials, and field notes on software engineering.
    </p>

    <div class="mt-14">
      {
        posts.length > 0 ? (
          [...years.entries()].map(([year, entries]) => (
            <section class="grid grid-cols-[8rem_minmax(0,1fr)] gap-8 border-t rule py-8 max-sm:block">
              <h2 class="display m-0 text-4xl text-accent">{year}</h2>
              <div>
                {entries.map((entry) => (
                  <ContentRow entry={entry} />
                ))}
              </div>
            </section>
          ))
        ) : (
          <div class="border-t border-[var(--accent)]">
            <EmptyState
              title="The writing archive is empty"
              path="content/posts/"
            />
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
